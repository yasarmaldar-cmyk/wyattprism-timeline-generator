  "rules": {
    "annual_report": { "closure_offset_from_agm_days": -30 },
    "integrated_report": { "closure_offset_from_agm_days": -30 },
    "sustainability_report": { "closure_offset_from_agm_days": null },
    "esg_report": { "closure_offset_from_agm_days": null }
  },
  "optional_modules": {
    "annual_report": [
      { "id": "print", "question": "Will print-ready files be required (vs digital-only)?", "default": true, "task_ids": ["ar_print_files"] }
    ],
    "integrated_report": [
      { "id": "print", "question": "Will print-ready files be required (vs digital-only)?", "default": true, "task_ids": ["ir_print_files"] }
    ],
    "sustainability_report": [
      { "id": "materiality_assessment", "question": "Will a fresh materiality assessment be conducted this cycle? (Skip if last year's matrix is being reused.)", "default": true, "task_ids": ["sr_stakeholder_list", "sr_stakeholder_questionnaire", "sr_stakeholder_engagement", "sr_materiality_draft", "sr_materiality_final"] },
      { "id": "external_assurance", "question": "Will the client engage external assurance for this report?", "default": false, "task_ids": ["sr_assurance_data", "sr_assurance_review", "sr_assurance_corrections"] },
      { "id": "print", "question": "Will print-ready files be required (vs digital-only)?", "default": false, "task_ids": ["sr_print_files"] }
    ],
    "esg_report": [
      { "id": "brsr_core_assurance", "question": "Is the client a top-listed entity required to file BRSR Core with reasonable assurance?", "default": false, "task_ids": ["esg_assurance_prep", "esg_assurance_review", "esg_assurance_corrections"] }
    ]
